# Built-in Entra ID app registration. Required for the "Sign in to Intune" button
# to work without users supplying their own Client ID.
#
# The app registration must be:
#  - Single Page Application (SPA) platform
#  - Multi-tenant (Supported account types: Accounts in any organizational directory)
#  - Redirect URIs: every host the app is served from (e.g. http://localhost:5173,
#    https://pppc.example.com)
#  - Delegated permissions (admin consent required):
#      DeviceManagementConfiguration.ReadWrite.All
#      DeviceManagementRBAC.Read.All
#      Group.Read.All
#      User.Read
#
# Copy this file to .env.local and fill in the values. .env.local is gitignored.

VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=organizations
